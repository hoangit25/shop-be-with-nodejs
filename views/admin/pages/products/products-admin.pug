extends ../../layout/default.pug
include ../../mixins/filter-status.pug
include ../../mixins/form-search.pug 
include ../../mixins/pagination.pug 
include ../../mixins/form-change-multi.pug
include ../../mixins/alert.pug
block main
  +alert-success(5000)

  h1 Danh sách sản phẩm
  .card.mb-3
    .card-header Sắp xếp
    .card-body
      .row 
          .col-6
            div(sort)
              select(
              class ="form control"
              name="sort"
              sort-select)
                option(disabled selected) --Chọn sắp xếp--
                option(value="price-desc") Giá giảm dần
                option(value="price-asc") Giá tăng dần
                option(value="position-desc") Vị trí giảm dần
                option(value="position-asc") Vị trí tăng dần
              button(
                class="btn btn-outline-danger btn-sm ml-2"
                clear-sort
              ) clear
  .card.mb-3
    .card-header Bộ lọc và Tìm kiếm
    .card-body 
      .row
        .col-3
          +filter-status(FilterStatus) 
        .col-3
          +form-search(Keyword)

  .card.mb-3
    .card-header Danh sách 
    .card-body
      .row
        .col-8
          +form-change-multi(`${prefixAdmin}/products/change-multi`)
        .col-4
          a(
            href=`${prefixAdmin}/products/create`
            class="btn btn-outline-success"
          ) +Thêm mới
    .card-body
      .table-responsive
        table(
          class="table table-hover table-sm"
          checkbox-multi
        )
          thead
            tr
              th 
                input(type="checkbox" name="checkall")
              th STT
              th Hình ảnh                  
              th Tiêu đề
              th Giá
              th vị trí
              th Trạng thái
              th Hành động
          tbody
            each item, index in products
              tr
                td
                  input(
                    type="checkbox"
                    name="id"
                    value=item.id
                  )
                td #{index + 1}
                td
                  img(
                    src=item.thumbnail
                    alt=`sản phẩm ${index + 1}`
                    width="100px"
                    height="auto"
                  )
                td #{item.title}
                td #{item.price}VND
                td
                  input(
                    type="number"
                    name="position"
                    value=item.position
                    min="1"
                    button-change-position
                  )
                td
                  if item.status === "active"
                    button(
                      class="badge badge-success"
                      data-status="active"
                      button-change-status
                      data-id=item.id
                    ) Hoạt động
                  else
                    button(
                      class="badge badge-danger"
                      data-status="inactive"
                      button-change-status
                      data-id=item.id
                    ) Không hoạt động
                td
                  a(href=`${prefixAdmin}/products/detail/${item.slug}`
                    class="btn btn-info btn-sm") Chi tiết
                  a(href=`${prefixAdmin}/products/edit/${item.id}`
                    class="btn btn-warning btn-sm") Sửa
                  button(
                    class="btn btn-danger btn-sm ml-1"
                    button-delete-product
                    data-id=item.id
                  ) Xóa     
  +paginations(pagination)

  form(action=""
   method="POST"
   id="form-change-status"
   data-path=`${prefixAdmin}/products/change-status`) 

  form(action=""
   method="POST"
   id="form-delete-product"
   data-path=`${prefixAdmin}/products/delete`)

  form(action=""
   method="POST"
   id="form-restore-product"
   data-path=`${prefixAdmin}/products/restore`)

  script(src="/admin/js/product.js")
 
